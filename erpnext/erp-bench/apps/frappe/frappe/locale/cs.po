#: frappe/core/doctype/scheduled_job_type/scheduled_job_type.json
#: frappe/core/doctype/server_script/server_script.json
msgid "<pre>*  *  *  *  *\n"
"┬  ┬  ┬  ┬  ┬\n"
"│  │  │  │  │\n"
"│  │  │  │  └ day of week (0 - 6) (0 is Sunday)\n"
"│  │  │  └───── month (1 - 12)\n"
