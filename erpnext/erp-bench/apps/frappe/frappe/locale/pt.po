"</code></pre>\n"
msgstr "<p><strong>Exemplos de condições:</strong></p>\n"
"<pre><code class=\"language-python\">doc.status==\"Open\"<br>doc.due_date==nowdate()<br>doc.total &gt; 40000\n"
