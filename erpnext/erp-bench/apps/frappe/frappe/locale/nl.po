"\tveldtype: \"Link\",\n"
"\topties: \"Bedrijf\",\n"
"\tstandaard: frappe.defaults.get_user_default(\"Bedrijf\"),\n"
"\tvereist: 1\n"
"},\n"
"{\n"
"\tveldnaam: \"account\",\n"
"\tlabel: __(\"Account\"),\n"
"\tveldtype: \"Link\",\n"
"\topties: \"Account\",\n"
"\tvereist: 1\n"
"}]\n"
