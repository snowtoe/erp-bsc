<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ba_load_plan_list" model="ir.ui.view">
        <field name="name">ba.load.plan.list</field>
        <field name="model">ba.load.plan</field>
        <field name="arch" type="xml">
            <list string="Gebindepläne">
                <field name="name"/>
                <field name="picking_id"/>
                <field name="partner_id"/>
                <field name="commission_group_id"/>
                <field name="commission_model_id"/>
                <field name="state"/>
                <field name="total_volume"/>
                <field name="total_weight"/>
                <field name="load_unit_count"/>
            </list>
        </field>
    </record>

    <record id="view_ba_load_plan_form" model="ir.ui.view">
        <field name="name">ba.load.plan.form</field>
        <field name="model">ba.load.plan</field>
        <field name="arch" type="xml">
            <form string="Gebindeplan">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="picking_id"/>
                            <field name="partner_id"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="commission_group_id"/>
                            <field name="commission_model_id"/>
                            <field name="tour_code"/>
                            <field name="delivery_date"/>
                        </group>
                    </group>

                    <group>
                        <field name="total_volume"/>
                        <field name="total_weight"/>
                    </group>

                    <notebook>
                        <page string="Gebinde">
                            <field name="load_unit_ids" nolabel="1">
                                <list>
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="load_unit_type_id"/>
                                    <field name="state"/>
                                    <field name="volume"/>
                                    <field name="weight"/>
                                    <field name="compartment_count"/>
                                </list>
                            </field>
                        </page>
                        <page string="Beschreibung">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_ba_load_unit_form" model="ir.ui.view">
        <field name="name">ba.load.unit.form</field>
        <field name="model">ba.load.unit</field>
        <field name="arch" type="xml">
            <form string="Gebinde">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="plan_id"/>
                            <field name="load_unit_type_id"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="sequence"/>
                            <field name="partner_id"/>
                            <field name="volume"/>
                            <field name="weight"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Fächer">
                            <field name="compartment_ids" nolabel="1">
                                <list>
                                    <field name="sequence"/>
                                    <field name="name"/>
                                    <field name="used_volume"/>
                                    <field name="highest_article_height"/>
                                    <field name="level_count"/>
                                    <field name="loss_volume"/>
                                </list>
                            </field>
                        </page>
                        <page string="Beschreibung">
                            <field name="note"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ba_load_plan" model="ir.actions.act_window">
        <field name="name">Gebindepläne</field>
        <field name="res_model">ba.load.plan</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
