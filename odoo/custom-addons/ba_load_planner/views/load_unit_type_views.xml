<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_ba_load_unit_type_list" model="ir.ui.view">
        <field name="name">ba.load.unit.type.list</field>
        <field name="model">ba.load.unit.type</field>
        <field name="arch" type="xml">
            <list string="Gebindearten">
                <field name="name"/>
                <field name="code"/>
                <field name="kind"/>
                <field name="length_cm"/>
                <field name="width_cm"/>
                <field name="max_height"/>
                <field name="max_volume"/>
                <field name="max_weight"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_ba_load_unit_type_form" model="ir.ui.view">
        <field name="name">ba.load.unit.type.form</field>
        <field name="model">ba.load.unit.type</field>
        <field name="arch" type="xml">
            <form string="Gebindeart">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="kind"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="length_cm"/>
                            <field name="width_cm"/>
                            <field name="max_height"/>
                            <field name="max_volume"/>
                            <field name="tare_weight"/>
                            <field name="max_weight"/>
                            <field name="max_compartments" invisible="kind != 'compartment'"/>
                        </group>
                    </group>
                    <group>
                        <field name="note"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ba_load_unit_type" model="ir.actions.act_window">
        <field name="name">Gebindearten</field>
        <field name="res_model">ba.load.unit.type</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
