<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_product_template_form_ba_load_planner" model="ir.ui.view">
        <field name="name">product.template.form.ba.load.planner</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet/notebook" position="inside">
                <page string="Load Planning">
                    <group>
                        <field name="volume"/>
                        <field name="weight"/>
                        <field name="ba_height"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
