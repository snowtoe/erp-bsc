<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_picking_form_ba_load_planner" model="ir.ui.view">
        <field name="name">stock.picking.form.ba.load.planner</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form/header" position="inside">
                <button name="action_compute_load_plan"
                        string="Gebindefindung berechnen"
                        type="object"
                        class="btn-primary"/>
                <button name="action_view_ba_load_plans"
                        string="Gebindepläne"
                        type="object"/>
            </xpath>

            <xpath expr="//sheet/notebook" position="inside">
                <page string="Load Planning">
                    <group>
                        <group>
                            <field name="ba_commission_group_id"/>
                            <field name="ba_tour_code"/>
                            <field name="ba_delivery_date"/>
                        </group>
                        <group>
                            <field name="ba_load_plan_count" readonly="1"/>
                        </group>
                    </group>

                    <field name="ba_load_plan_ids" nolabel="1">
                        <list>
                            <field name="name"/>
                            <field name="commission_model_id"/>
                            <field name="state"/>
                            <field name="total_volume"/>
                            <field name="total_weight"/>
                            <field name="load_unit_count"/>
                        </list>
                    </field>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
